# PostgreSQL connection for the app at runtime.
# On Supabase use the transaction pooler (port 6543) with pgbouncer=true.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&connection_limit=1"

# Direct connection used by prisma migrate (DDL does not work through
# a transaction-mode pooler). On Supabase use the session pooler, port 5432.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# HTTP Basic Auth credentials for the /admin panel.
# The app refuses all admin access if these are not set.
ADMIN_USER="admin"
ADMIN_PASSWORD="change-me"

# Note: the OpenAI API key and the fallback n8n webhook URL are configured
# in the app under /admin/settings, not here.
